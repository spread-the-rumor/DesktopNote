RECALL_API_KEY=your_recall_api_key_here
RECALL_API_URL=https://us-west-2.recall.ai

# Slack Bot User OAuth Token for the "Send to Slack" feature. This powers both
# the channel dropdown and the actual send (via the Web API, chat.postMessage),
# so the user can pick any channel — unlike an Incoming Webhook, which is locked
# to one channel. Create/install your app at https://api.slack.com/apps, then
# copy the "Bot User OAuth Token" (starts with xoxb-).
# Required bot scopes: chat:write, channels:read, groups:read (private channels),
# channels:join (auto-join public channels before posting).
Bot_User_OAuth_Token=

# Deprecated / unused: the old single-channel Incoming Webhook. The app now uses
# the bot token above. Safe to leave blank or remove.
SLACK_WEBHOOK_URL=

# Optional: API key for AI meeting summaries via requesty.ai (OpenAI-compatible
# chat completions). If unset, the UI shows a readable "Summary unavailable" note
# instead of a summary. Get one at https://requesty.ai.
REQUESTY_API_KEY=

# Optional: GetOverview (internal PM tool) integration. Powers the "GetOverview"
# panel in the editor — listing projects, creating tasks from action items, and
# submitting the summary/transcript. If unset, those controls degrade to a
# readable "not configured" state and the rest of the app is unaffected.
# Base URL has no trailing slash, e.g. https://api.getoverview.io
# Token is a Personal Access Token (starts with go_live_), sent as a Bearer token.
GetOverview_BASE_URL=
GetOverview_Access_Token=
